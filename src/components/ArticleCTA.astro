---
import { ARTICLE_LOCALES } from '../data/articleLocales.mjs';

type ArticleLocale = keyof typeof ARTICLE_LOCALES;

interface Props {
  includeGuidesLink?: boolean;
  locale?: ArticleLocale;
}
const { includeGuidesLink = true, locale = 'en' } = Astro.props;
const copy = ARTICLE_LOCALES[locale].cta;
---

<section class="article-cta" aria-labelledby="article-cta-title">
  <div class="article-cta-copy-block">
    <h2 id="article-cta-title" class="article-cta-title">
      {copy[0]}
    </h2>
    <p class="article-cta-copy">
      {copy[1]}
    </p>
  </div>

  <div class="cta-actions article-cta-actions" aria-label={copy[2]}>
    <a class="cta-action cta-action-primary article-cta-action" href="/#features">
      {copy[3]}
    </a>
    {includeGuidesLink && (
      <a class="cta-action cta-action-secondary article-cta-action" href={ARTICLE_LOCALES[locale].root}>
        {copy[4]}
      </a>
    )}
  </div>
</section>
