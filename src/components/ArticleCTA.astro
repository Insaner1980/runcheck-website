---
interface Props {
  includeGuidesLink?: boolean;
}

const { includeGuidesLink = true } = Astro.props;
---

<section class="article-cta" aria-labelledby="article-cta-title">
  <div class="article-cta-copy-block">
    <p class="article-cta-eyebrow">runcheck</p>
    <h2 id="article-cta-title" class="article-cta-title">Turn symptoms into a clearer phone-health picture.</h2>
    <p class="article-cta-copy">
      runcheck connects battery, heat, signal, and storage patterns so you can see what is really dragging a phone down.
    </p>
  </div>

  <div class="cta-actions article-cta-actions" aria-label="runcheck next steps">
    <a class="cta-action cta-action-primary article-cta-action" href="/#features">See what runcheck checks</a>
    {includeGuidesLink && <a class="cta-action cta-action-secondary article-cta-action" href="/articles/">Browse more guides</a>}
  </div>
</section>
