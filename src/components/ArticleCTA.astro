---
import { ARTICLE_LOCALES } from '../data/articleLocales.mjs';

type ArticleLocale = keyof typeof ARTICLE_LOCALES;

interface Props {
  includeGuidesLink?: boolean;
  locale?: ArticleLocale;
}
const { includeGuidesLink = true, locale = 'en' } = Astro.props;
const ctaCopy = {
  en: ["Turn symptoms into a clearer picture of your phone's health.", 'runcheck connects battery, heat, signal, and storage patterns so you can see what is really dragging a phone down.', 'runcheck next steps', 'See what runcheck checks', 'Browse more guides'],
  fi: ['Muodosta oireista selkeä kokonaiskuva puhelimesi kunnosta.', 'runcheck yhdistää akun, lämmön, signaalin ja tallennustilan havainnot, jotta näet, mikä puhelinta todella hidastaa.', 'runcheckin seuraavat vaiheet', 'Katso, mitä runcheck tarkistaa', 'Selaa muita oppaita'],
  sv: ['Gör symtomen till en tydligare bild av telefonens hälsa.', 'runcheck kopplar samman mönster för batteri, värme, signal och lagring så att du ser vad som faktiskt bromsar telefonen.', 'Nästa steg med runcheck', 'Se vad runcheck kontrollerar', 'Bläddra bland fler guider'],
  nb: ['Gjør symptomene om til et tydeligere bilde av telefonens helse.', 'runcheck kobler sammen mønstre for batteri, varme, signal og lagring, slik at du ser hva som faktisk holder telefonen tilbake.', 'Neste trinn med runcheck', 'Se hva runcheck sjekker', 'Se flere guider'],
  de: ['Mach aus den Symptomen ein klareres Bild vom Zustand deines Smartphones.', 'runcheck verknüpft Muster bei Akku, Wärme, Signal und Speicher, damit du erkennst, was dein Smartphone wirklich ausbremst.', 'Nächste Schritte mit runcheck', 'Das prüft runcheck', 'Weitere Ratgeber ansehen'],
  da: ['Få et tydeligere billede af telefonens tilstand ud fra symptomerne.', 'runcheck samler mønstre for batteri, varme, signal og lagerplads, så du kan se, hvad der faktisk holder telefonen tilbage.', 'Næste trin med runcheck', 'Se, hvad runcheck kontrollerer', 'Se flere guides'],
  fr: ['Transformez les symptômes en une vision plus claire de l’état de votre téléphone.', 'runcheck relie les signaux de la batterie, de la température, du réseau et du stockage pour vous montrer ce qui ralentit vraiment votre téléphone.', 'Les prochaines étapes avec runcheck', 'Voir ce que runcheck vérifie', 'Parcourir d’autres guides'],
  es: ['Convierte los síntomas en una imagen más clara del estado de tu teléfono.', 'runcheck relaciona los patrones de batería, temperatura, señal y almacenamiento para mostrarte qué está frenando realmente tu teléfono.', 'Próximos pasos con runcheck', 'Descubre qué comprueba runcheck', 'Ver más guías'],
};
const copy = ctaCopy[locale];
---

<section class="article-cta" aria-labelledby="article-cta-title">
  <div class="article-cta-copy-block">
    <h2 id="article-cta-title" class="article-cta-title">
      {copy[0]}
    </h2>
    <p class="article-cta-copy">
      {copy[1]}
    </p>
  </div>

  <div class="cta-actions article-cta-actions" aria-label={copy[2]}>
    <a class="cta-action cta-action-primary article-cta-action" href="/#features">
      {copy[3]}
    </a>
    {includeGuidesLink && (
      <a class="cta-action cta-action-secondary article-cta-action" href={ARTICLE_LOCALES[locale].root}>
        {copy[4]}
      </a>
    )}
  </div>
</section>
