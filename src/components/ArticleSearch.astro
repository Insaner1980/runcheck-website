---
interface Props {
  variant?: 'header' | 'page';
}

const { variant = 'header' } = Astro.props;
const isHeader = variant === 'header';
const inputId = `article-search-input-${variant}`;
const resultsId = `article-search-results-${variant}`;
---

<div
  class:list={[
    'article-search relative',
    isHeader ? 'flex items-center justify-end' : 'block w-full',
  ]}
  data-article-search
  data-variant={variant}
>
  <div
    class:list={[
      'search-field relative',
      isHeader
        ? 'h-10 w-10 motion-safe:transition-[width] motion-safe:duration-200 motion-safe:ease-out motion-reduce:transition-none data-[open=true]:w-72 md:data-[open=true]:w-80'
        : 'w-full max-w-xl',
    ]}
    data-search-field
    data-open={String(!isHeader)}
  >
    <div
      class:list={[
        'search-shell relative flex h-10 w-full items-center text-run-white',
        isHeader ? 'hero-nav-search-shell overflow-hidden rounded-panel data-[open=true]:pr-2' : 'gap-2',
      ]}
      data-search-shell
      data-open={String(!isHeader)}
    >
      {isHeader ? (
        <button
          type="button"
          class="hero-nav-action hero-nav-icon-action"
          aria-label="Search articles"
          aria-expanded="false"
          aria-controls={inputId}
          data-search-toggle
        >
          <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" data-search-icon>
            <circle cx="11" cy="11" r="7"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
        </button>
      ) : (
        <svg class="size-5 shrink-0 text-run-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" data-search-icon>
          <circle cx="11" cy="11" r="7"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
      )}
      <label class="sr-only" for={inputId}>Search articles</label>
      <input
        id={inputId}
        type="search"
        class:list={[
          'min-w-0 appearance-none bg-transparent py-1.5 focus:outline-none [&::-webkit-search-cancel-button]:hidden [&::-webkit-search-decoration]:hidden',
          isHeader
            ? 'w-full flex-1 text-sm font-medium leading-5 text-run-white placeholder:text-run-white opacity-0 motion-safe:transition-opacity motion-safe:duration-150 motion-reduce:transition-none data-[open=true]:opacity-100'
            : 'w-full text-base text-run-text placeholder:text-run-muted',
        ]}
        placeholder="Search articles"
        autocomplete="off"
        role="combobox"
        aria-expanded="false"
        aria-controls={resultsId}
        aria-autocomplete="list"
        tabindex={isHeader ? '-1' : undefined}
        data-search-input
        data-open={String(!isHeader)}
      />
      {isHeader && (
        <button
          type="button"
          class="pointer-events-none hero-nav-inline-icon-action shrink-0 opacity-0 data-[open=true]:pointer-events-auto data-[open=true]:opacity-100 motion-safe:transition-opacity motion-safe:duration-150 motion-reduce:transition-none"
          aria-label="Close search"
          data-search-close
          data-open="false"
        >
          <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      )}
      {!isHeader && (
        <div
          class="pointer-events-none absolute bottom-0 left-0 right-0 h-px origin-left scale-x-0 bg-run-border motion-safe:transition-transform motion-safe:duration-200 motion-safe:ease-out motion-reduce:transition-none data-[active=true]:scale-x-100 data-[active=true]:bg-run-white/60"
          data-search-underline
          data-active={String(!isHeader)}
          aria-hidden="true"
        ></div>
      )}
    </div>

    <ul
      id={resultsId}
      class="search-results hero-nav-panel pointer-events-none absolute left-0 right-0 top-full z-50 mt-2 max-h-80 overflow-y-auto rounded-panel p-1.5 opacity-0 -translate-y-1 motion-safe:transition motion-safe:duration-150 motion-safe:ease-out motion-reduce:transition-none data-[open=true]:pointer-events-auto data-[open=true]:translate-y-0 data-[open=true]:opacity-100"
      role="listbox"
      aria-label="Search results"
      data-search-results
      data-open="false"
    ></ul>
  </div>
</div>

<script>
  import { searchArticles } from '../data/searchIndex.mjs';

  let indexPromise = null;

  const loadIndex = () => {
    indexPromise ??= fetch('/articles/search-index.json')
      .then((response) => {
        if (!response.ok) {
          throw new Error(`Search index failed: ${response.status}`);
        }
        return response.json();
      })
      .catch((error) => {
        indexPromise = null;
        throw error;
      });

    return indexPromise;
  };

  const widgets = document.querySelectorAll('[data-article-search]');

  widgets.forEach((widget) => {
    const toggle = widget.querySelector('[data-search-toggle]');
    const close = widget.querySelector('[data-search-close]');
    const field = widget.querySelector('[data-search-field]');
    const shell = widget.querySelector('[data-search-shell]');
    const input = widget.querySelector('[data-search-input]');
    const underline = widget.querySelector('[data-search-underline]');
    const results = widget.querySelector('[data-search-results]');

    if (!(input instanceof HTMLInputElement) || !(field instanceof HTMLElement) || !(shell instanceof HTMLElement) || !(results instanceof HTMLElement)) {
      return;
    }

    const isHeader = widget.getAttribute('data-variant') === 'header';
    let index = [];
    let current = [];
    let activeIndex = -1;

    const optionId = (i) => `${results.id}-option-${i}`;

    const setFieldOpen = (open) => {
      field.dataset.open = String(open);
      shell.dataset.open = String(open);
      input.dataset.open = String(open);
      input.tabIndex = isHeader && !open ? -1 : 0;
      if (toggle instanceof HTMLButtonElement) {
        toggle.setAttribute('aria-expanded', String(open));
      }
      if (close instanceof HTMLButtonElement) {
        close.dataset.open = String(open);
      }
    };

    const setResultsOpen = (open) => {
      results.dataset.open = String(open);
      input.setAttribute('aria-expanded', String(open));
      if (!open) {
        activeIndex = -1;
        input.removeAttribute('aria-activedescendant');
      }
    };

    const setUnderlineActive = (active) => {
      if (underline instanceof HTMLElement) {
        underline.dataset.active = String(active);
      }
    };

    const appendStatus = (message) => {
      const item = document.createElement('li');
      item.className = 'px-3 py-2.5 text-sm text-run-white/55';
      item.setAttribute('role', 'option');
      item.setAttribute('aria-disabled', 'true');
      item.textContent = message;
      results.replaceChildren(item);
      setResultsOpen(true);
    };

    const appendResult = (item, i) => {
      const option = document.createElement('li');
      option.id = optionId(i);
      option.setAttribute('role', 'option');
      option.setAttribute('aria-selected', String(i === activeIndex));

      const link = document.createElement('a');
      link.href = item.url;
      link.className = 'hero-nav-panel-link';
      link.dataset.active = String(i === activeIndex);

      const title = document.createElement('span');
      title.className = 'block truncate text-sm font-semibold leading-5';
      title.textContent = item.title;

      const hub = document.createElement('span');
      hub.className = 'mt-0.5 block truncate font-mono text-[0.62rem] font-medium uppercase tracking-[0.22em] leading-4 text-run-white/40';
      hub.textContent = item.hub;

      link.append(title, hub);
      option.append(link);
      results.append(option);
    };

    const render = () => {
      if (current.length === 0) {
        if (input.value.trim() === '') {
          results.replaceChildren();
          setResultsOpen(false);
          return;
        }
        appendStatus('No results');
        return;
      }

      results.replaceChildren();
      current.forEach(appendResult);
      setResultsOpen(true);
    };

    const showSearchError = () => {
      current = [];
      appendStatus('Search unavailable');
    };

    const runQuery = async () => {
      if (input.value.trim() === '') {
        current = [];
        render();
        return;
      }

      try {
        if (index.length === 0) {
          index = await loadIndex();
        }
        current = searchArticles(index, input.value);
        activeIndex = -1;
        render();
      } catch {
        showSearchError();
      }
    };

    const move = (delta) => {
      if (current.length === 0) {
        return;
      }
      activeIndex = (activeIndex + delta + current.length) % current.length;
      input.setAttribute('aria-activedescendant', optionId(activeIndex));
      render();
      const active = results.querySelector('[aria-selected="true"] a');
      if (active instanceof HTMLElement) {
        active.scrollIntoView({ block: 'nearest' });
      }
    };

    const go = () => {
      const target = current[activeIndex >= 0 ? activeIndex : 0];
      if (target) {
        window.location.href = target.url;
      }
    };

    const closeAll = ({ collapseHeader = false } = {}) => {
      setResultsOpen(false);
      setUnderlineActive(!isHeader && document.activeElement === input);
      if (isHeader && collapseHeader) {
        setFieldOpen(false);
      }
    };

    input.addEventListener('focus', () => {
      void loadIndex().catch(() => undefined);
      setUnderlineActive(true);
      if (input.value.trim() !== '') {
        void runQuery();
      }
    });

    input.addEventListener('input', () => {
      void runQuery();
    });

    input.addEventListener('keydown', (event) => {
      if (event.key === 'ArrowDown') {
        event.preventDefault();
        move(1);
      } else if (event.key === 'ArrowUp') {
        event.preventDefault();
        move(-1);
      } else if (event.key === 'Enter') {
        event.preventDefault();
        go();
      } else if (event.key === 'Escape') {
        event.preventDefault();
        input.value = '';
        current = [];
        closeAll({ collapseHeader: true });
        if (isHeader && toggle instanceof HTMLButtonElement) {
          toggle.focus();
        }
      }
    });

    if (toggle instanceof HTMLButtonElement) {
      toggle.addEventListener('click', () => {
        if (field.dataset.open !== 'true') {
          setFieldOpen(true);
          void loadIndex().catch(() => undefined);
        }
        input.focus();
      });
    }

    if (close instanceof HTMLButtonElement) {
      close.addEventListener('click', () => {
        input.value = '';
        current = [];
        closeAll({ collapseHeader: true });
        if (toggle instanceof HTMLButtonElement) {
          toggle.focus();
        }
      });
    }

    document.addEventListener('pointerdown', (event) => {
      if (event.target instanceof Node && widget.contains(event.target)) {
        return;
      }
      closeAll({ collapseHeader: true });
    });
  });
</script>
