---
import { Image } from 'astro:assets';
import ctaBackground from '../assets/runcheck-phone-diagnostics-cta-background.webp';
---

<section id="download" class="cta-section" aria-labelledby="cta-title">
  <Image
    src={ctaBackground}
    alt=""
    class="cta-background-image"
    loading="lazy"
    decoding="async"
  />

  <div class="cta-inner">
    <p class="cta-eyebrow">Coming fall 2026</p>
    <h2 id="cta-title" class="cta-title">Stop guessing. Start checking.</h2>
    <p class="cta-copy">Free to download when runcheck launches. Pro unlocks deeper history. No accounts, ever.</p>

    <div class="cta-actions" aria-label="runcheck next steps">
      <a class="cta-action cta-action-primary" href="/articles/">Read the guides</a>
      <a class="cta-action cta-action-secondary" href="/#features">See what runcheck checks</a>
    </div>
  </div>
</section>
