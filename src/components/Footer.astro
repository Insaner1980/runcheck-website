---
import { Image } from 'astro:assets';
import logo from '../assets/runcheck-logo.webp';
import { ARTICLE_LOCALES } from '../data/articleLocales.mjs';

const year = new Date().getFullYear();
const { locale = 'en' } = Astro.props;
const copy = ARTICLE_LOCALES[locale];
---

<footer class="site-footer bg-run-bg">
  <div class="mx-auto flex max-w-[100rem] flex-col items-center gap-7 px-5 py-12 md:grid md:grid-cols-[1fr_auto_1fr] md:gap-4">
    <a href="/" class="flex items-center gap-3 md:justify-self-start" aria-label="runcheck home">
      <Image src={logo} alt="" class="size-7 shrink-0 object-contain" loading="lazy" />
      <span class="text-base lowercase leading-none font-semibold text-run-text">runcheck</span>
    </a>

    <nav class="footer-nav flex flex-col items-center gap-4 sm:flex-row sm:gap-9" aria-label={copy.menu[3]}>
      <a href="/#features">{copy.nav[0]}</a>
      <a href={copy.root}>{copy.nav[1]}</a>
      <a href="mailto:contact@finnvek.com">{copy.nav[2]}</a>
    </nav>

    <div class="footer-meta flex flex-col items-center gap-1.5 md:justify-self-end md:items-end">
      <p class="footer-copyright">&copy; {year} runcheck</p>
      <a class="footer-finnvek" href="https://finnvek.com">Finnvek</a>
    </div>
  </div>
</footer>
