---
import { Image } from 'astro:assets';
import logo from '../assets/runcheck-logo.webp';
import { ARTICLE_MENU_COLUMNS } from '../data/articleTaxonomy.mjs';
import ArticleSearch from './ArticleSearch.astro';

const navLinks = [
  { href: '/#features', label: 'Features' },
];
---

<header class="absolute inset-x-0 top-0 z-50">
  <div class="mx-auto flex max-w-[100rem] items-center justify-between gap-4 px-5 py-5">
    <a href="/" class="flex min-w-0 items-center gap-3 font-semibold text-run-text" aria-label="runcheck home">
      <Image
        src={logo}
        alt=""
        class="size-9 shrink-0 object-contain"
        loading="eager"
        fetchpriority="high"
      />
      <span class="brand-shine-text text-lg lowercase leading-none" data-text="runcheck">runcheck</span>
    </a>

    <div class="order-3 md:hidden">
      <button
        type="button"
        class="hero-nav-action hero-nav-icon-action group"
        aria-expanded="false"
        aria-controls="primary-nav"
        aria-label="Open menu"
        data-nav-toggle
      >
        <svg class="size-6 group-aria-[expanded=true]:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
        <svg class="hidden size-6 group-aria-[expanded=true]:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    <nav
      id="primary-nav"
      data-primary-nav
      data-open="false"
      aria-label="Primary navigation"
      class:list={[
        'text-sm font-medium text-run-white',
        'absolute left-5 right-5 top-20 z-50 flex flex-col items-stretch gap-1.5 rounded-panel p-3',
        'max-md:border max-md:border-[color:var(--run-hero-nav-panel-edge)] max-md:bg-[color:var(--run-hero-nav-panel-bg)] max-md:shadow-[var(--run-hero-nav-panel-shadow)] max-md:backdrop-blur-[var(--run-glass-blur)]',
        'pointer-events-none -translate-y-1 opacity-0 data-[open=true]:pointer-events-auto data-[open=true]:translate-y-0 data-[open=true]:opacity-100',
        'motion-safe:transition motion-safe:duration-150 motion-safe:ease-out motion-reduce:transition-none',
        'md:pointer-events-auto md:static md:translate-y-0 md:shrink-0 md:flex-row md:items-center md:justify-end md:gap-x-2 md:p-0 md:opacity-100',
      ]}
    >
      {navLinks.map((link) => (
        <a class="hero-nav-action" href={link.href} data-hero-nav-label={link.label}>
          <span class="hero-nav-label">{link.label}</span>
          <span class="hero-nav-label-gradient" aria-hidden="true">{link.label}</span>
        </a>
      ))}

      <div class="articles-menu relative" data-articles-menu>
        <button
          id="articles-menu-button"
          type="button"
          class="hero-nav-action"
          aria-expanded="false"
          aria-controls="articles-menu-panel"
          data-hero-nav-label="Articles"
          data-articles-menu-button
        >
          <span class="hero-nav-label">Articles</span>
          <span class="hero-nav-label-gradient" aria-hidden="true">Articles</span>
        </button>

        <div
          id="articles-menu-panel"
          class="hero-nav-panel pointer-events-none fixed inset-x-5 top-20 z-50 max-h-[calc(100vh-6rem)] overflow-y-auto rounded-panel p-5 opacity-0 -translate-y-1 data-[open=true]:pointer-events-auto data-[open=true]:translate-y-0 data-[open=true]:opacity-100 motion-safe:transition motion-safe:duration-150 motion-safe:ease-out motion-reduce:transition-none md:absolute md:inset-x-auto md:right-0 md:top-full md:mt-4 md:w-[64rem] md:max-w-[calc(100vw-2.5rem)] md:p-6"
          data-articles-menu-panel
          data-open="false"
          aria-hidden="true"
          aria-labelledby="articles-menu-button"
          inert
        >
          <div class="grid grid-cols-1 gap-7 md:grid-cols-3 md:gap-8">
            {ARTICLE_MENU_COLUMNS.map((group) => (
              <section class="min-w-0" aria-labelledby={`articles-menu-${group.title.toLowerCase().replaceAll(/[^a-z0-9]+/g, '-')}`}>
                <h2
                  id={`articles-menu-${group.title.toLowerCase().replaceAll(/[^a-z0-9]+/g, '-')}`}
                  class="mb-4 font-mono text-xs font-semibold uppercase tracking-widest text-run-white/50"
                >
                  {group.title}
                </h2>

                <ul class="grid gap-2.5" role="list">
                  {group.hubs.map((item) => (
                    <li>
                      <a
                        href={item.href}
                        class="hero-nav-panel-link"
                      >
                        <span class="block text-base font-semibold leading-5 text-run-white">{item.title}</span>
                        <span class="mt-1 block truncate text-xs leading-4 text-run-white/55">{item.description}</span>
                      </a>
                    </li>
                  ))}
                </ul>
              </section>
            ))}
          </div>
        </div>
      </div>

      <ArticleSearch variant="header" />
    </nav>
  </div>
</header>

<script>
  const articleMenus = document.querySelectorAll('[data-articles-menu]');

  articleMenus.forEach((menu) => {
    const button = menu.querySelector('[data-articles-menu-button]');
    const panel = menu.querySelector('[data-articles-menu-panel]');

    if (!(button instanceof HTMLButtonElement) || !(panel instanceof HTMLElement)) {
      return;
    }

    let clickOpen = false;

    const isOpen = () => button.getAttribute('aria-expanded') === 'true';

    const setOpen = (open) => {
      button.setAttribute('aria-expanded', String(open));
      panel.dataset.open = String(open);
      panel.setAttribute('aria-hidden', String(!open));

      if (open) {
        panel.removeAttribute('inert');
        return;
      }

      panel.setAttribute('inert', '');
    };

    button.addEventListener('click', () => {
      clickOpen = !clickOpen;
      setOpen(clickOpen);
    });

    menu.addEventListener('pointerenter', (event) => {
      if (event.pointerType === 'mouse') {
        setOpen(true);
      }
    });

    menu.addEventListener('pointerleave', (event) => {
      if (event.pointerType !== 'mouse' || clickOpen || menu.contains(document.activeElement)) {
        return;
      }

      setOpen(false);
    });

    menu.addEventListener('focusin', () => {
      setOpen(true);
    });

    menu.addEventListener('focusout', (event) => {
      if (event.relatedTarget instanceof Node && menu.contains(event.relatedTarget)) {
        return;
      }

      clickOpen = false;
      setOpen(false);
    });

    panel.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        clickOpen = false;
        setOpen(false);
      });
    });

    document.addEventListener('pointerdown', (event) => {
      if (!(event.target instanceof Node) || menu.contains(event.target)) {
        return;
      }

      clickOpen = false;
      setOpen(false);
    });

    document.addEventListener('keydown', (event) => {
      if (event.key !== 'Escape' || !isOpen()) {
        return;
      }

      clickOpen = false;
      button.focus();
      setOpen(false);
    });
  });

  // Mobiilin hampurilaisvalikko: avaa/sulkee navigaatiopaneelin pienillä näytöillä
  const navToggle = document.querySelector('[data-nav-toggle]');
  const primaryNav = document.querySelector('[data-primary-nav]');

  if (navToggle instanceof HTMLButtonElement && primaryNav instanceof HTMLElement) {
    const desktopQuery = window.matchMedia('(min-width: 768px)');

    const setNavOpen = (open) => {
      primaryNav.dataset.open = String(open);
      navToggle.setAttribute('aria-expanded', String(open));
      navToggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');

      // Suljettu mobiilipaneeli ei saa olla näppäimistöllä tavoitettavissa,
      // mutta työpöydällä navi on aina aktiivinen.
      if (open || desktopQuery.matches) {
        primaryNav.removeAttribute('inert');
      } else {
        primaryNav.setAttribute('inert', '');
      }
    };

    navToggle.addEventListener('click', () => {
      setNavOpen(primaryNav.dataset.open !== 'true');
    });

    primaryNav.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => setNavOpen(false));
    });

    document.addEventListener('pointerdown', (event) => {
      if (primaryNav.dataset.open !== 'true' || !(event.target instanceof Node)) {
        return;
      }

      if (primaryNav.contains(event.target) || navToggle.contains(event.target)) {
        return;
      }

      setNavOpen(false);
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && primaryNav.dataset.open === 'true') {
        setNavOpen(false);
        navToggle.focus();
      }
    });

    // Sulje mobiilipaneeli leveyden vaihtuessa ja päivitä inert-tila molempiin suuntiin
    desktopQuery.addEventListener('change', () => {
      setNavOpen(false);
    });

    // Aseta alkutila (mobiilissa inert, työpöydällä aktiivinen)
    setNavOpen(false);
  }
</script>
