<section id="hero" class="hero-section relative isolate overflow-hidden bg-run-bg">
  <div class="hero-inner relative z-10 mx-auto w-full max-w-[86rem] px-5 pt-24 sm:pt-28 lg:px-8">
    <div class="hero-grid">
      <div class="hero-copy">
        <h1 class="hero-title font-display">
          <span class="hero-line"><span class="hero-line-inner hero-title-line bg-clip-text text-transparent [background-image:var(--run-headline-metal-fill)] [filter:var(--run-headline-line-filter)]">Your phone's</span></span>
          <span class="hero-line hero-line-main"><span class="hero-line-inner hero-title-line"><span class="hero-real-outline">real</span><span class="bg-clip-text text-transparent [background-image:var(--run-headline-metal-fill)] [filter:var(--run-headline-line-filter)]">condition</span></span></span>
        </h1>

        <p class="hero-copyline">
          Battery draining faster, running warm, or getting slower every month? runcheck connects the symptoms so you know what changed and why.
        </p>

        <p class="hero-kicker">Coming fall 2026</p>
      </div>

      <div class="hero-visual" aria-label="runcheck app preview">
        <div class="hero-phone-stage">
          <img
            src="/assets/runcheck-phone-condition-hero.webp"
            alt="runcheck phone condition check app shown on a smartphone"
            class="hero-phone-image"
            width="568"
            height="1176"
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
          <div class="hero-phone-mirror" aria-hidden="true">
            <img
              src="/assets/runcheck-phone-condition-hero.webp"
              alt=""
              width="568"
              height="1176"
              loading="eager"
              decoding="async"
            />
          </div>
        </div>
      </div>
    </div>

    <div class="hero-baseline" aria-hidden="true"></div>
  </div>
</section>
