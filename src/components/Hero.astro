---
import { Image } from 'astro:assets';
import heroPhone from '../assets/runcheck-android-phone-diagnostics-hero.webp';
---

<section id="hero" class="hero-section relative isolate overflow-hidden bg-run-bg">
  <Image
    src={heroPhone}
    alt=""
    class="absolute inset-0 h-full w-full select-none object-cover object-[20%_center] sm:object-[34%_center] lg:object-[46%_center]"
    loading="eager"
    fetchpriority="high"
  />
  <div class="hero-phone-screen-pulse" aria-hidden="true"></div>

  <div class="hero-inner relative z-10 mx-auto grid min-h-[100svh] max-w-[100rem] px-5 pb-8 pt-28 sm:pt-32 lg:h-full lg:min-h-0 lg:grid-cols-[minmax(0,34rem)_1fr_minmax(18rem,24rem)] lg:items-start lg:gap-8 lg:pb-10">
    <div class="relative max-w-[31rem] lg:col-start-1">
      <h1
        class="hero-title font-display max-w-[10ch] uppercase tracking-normal"
      >
        <span class="relative z-10 block w-max whitespace-nowrap bg-clip-text text-transparent [background-image:var(--run-headline-metal-fill)] [filter:var(--run-headline-line-filter)]">Know your</span>
        <span class="relative z-20 block w-max whitespace-nowrap bg-clip-text text-transparent [background-image:var(--run-headline-metal-fill)] [filter:var(--run-headline-line-filter)]">phone's</span>
        <span class="hero-real-word relative z-30 block w-max whitespace-nowrap bg-clip-text text-transparent [background-image:var(--run-headline-blue-fill)] [filter:var(--run-headline-line-filter)]">real</span>
        <span class="relative z-40 block w-max whitespace-nowrap bg-clip-text text-transparent [background-image:var(--run-headline-metal-fill)] [filter:var(--run-headline-line-filter)]">condition</span>
      </h1>

      <div class="mt-36 flex max-w-md flex-col items-start">
        <span class="hero-release-chip">
          Coming fall 2026
        </span>
      </div>
    </div>

    <div class="hero-focus-list mt-8 flex flex-col items-start gap-3 lg:col-start-3 lg:mt-0 lg:mr-0 lg:self-center lg:-translate-y-12 lg:gap-4 lg:justify-self-end xl:mr-0" aria-label="runcheck diagnostic prompts">
      <span class="hero-focus-line hero-focus-line-1">Battery draining faster than it used to?</span>
      <span class="hero-focus-line hero-focus-line-2">Running warm for no reason?</span>
      <span class="hero-focus-line hero-focus-line-3">Slower every month?</span>
      <span class="hero-focus-line hero-focus-line-4">Now you'll know why.</span>
    </div>
  </div>
</section>
