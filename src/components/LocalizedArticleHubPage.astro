---
import ArticleCTA from './ArticleCTA.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { ARTICLE_LOCALES } from '../data/articleLocales.mjs';
import { articlePath } from '../data/articlePaths.mjs';
import { buildBreadcrumbJsonLd, normalizeMetaDescription } from '../data/seo.mjs';

const { locale, hub, articles, alternateLocales } = Astro.props;
const copy = ARTICLE_LOCALES[locale];
const sections = hub.sections ?? [{ sourceNumbers: hub.sourceNumbers }];
const site = Astro.site ?? new URL('https://runcheckapp.com');
const breadcrumbJsonLd = buildBreadcrumbJsonLd([
  { name: 'runcheck', path: '/' }, { name: copy.articles, path: copy.root }, { name: hub.title, path: hub.href },
], site);
---

<BaseLayout title={`${hub.title} | runcheck`} description={normalizeMetaDescription(hub.metaDescription ?? hub.description)} canonicalPath={hub.href} lang={locale} alternateLocales={alternateLocales} jsonLd={breadcrumbJsonLd}>
  <section class="border-b border-run-border">
    <div class="article-page-shell article-page-shell-medium">
      <h1 class="text-4xl font-semibold text-run-text sm:text-5xl">{hub.title}</h1>
      <p class="mt-5 max-w-2xl text-lg text-run-muted">{hub.description}</p>
      <div class="mt-12 grid gap-12">
        {sections.map((section) => {
          const sectionArticles = articles.filter((article) => section.sourceNumbers.includes(article.data.sourceNumber));
          return <section>
            {section.title && <h2 class="font-mono text-xs font-semibold uppercase tracking-widest text-run-muted">{section.title}</h2>}
            <ul class="article-link-list" role="list">{sectionArticles.map((article) => <li><a class="article-list-link" href={articlePath(hub.slug, article.id, locale)}><span class="article-list-title">{article.data.title}</span><span class="article-list-description">{article.data.listSummary ?? article.data.description}</span></a></li>)}</ul>
          </section>;
        })}
      </div>
      <ArticleCTA locale={locale} />
    </div>
  </section>
</BaseLayout>
