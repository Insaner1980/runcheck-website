---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const articles = (await getCollection('articles', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime(),
);
const dateFormatter = new Intl.DateTimeFormat('en', { dateStyle: 'medium' });
---

<BaseLayout
  title="runcheck articles"
  description="Articles about Windows battery, thermal, network, storage, and system health checks."
  canonicalPath="/articles/"
>
  <section class="border-b border-run-border">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <p class="mb-4 font-mono text-xs font-semibold uppercase tracking-widest text-run-cyan">Articles</p>
      <h1 class="max-w-3xl text-4xl font-semibold text-run-text sm:text-5xl">runcheck articles</h1>
      <ul class="mt-10 grid gap-4">
        {articles.map((article) => (
          <li class="rounded-panel border border-run-border bg-run-surface p-5 shadow-panel">
            <a class="text-xl font-semibold text-run-text transition hover:text-run-cyan" href={`/articles/${article.id}/`}>
              {article.data.title}
            </a>
            <p class="mt-3 text-run-muted">{article.data.description}</p>
            <p class="mt-4 font-mono text-xs uppercase tracking-widest text-run-muted">
              {article.data.category} / {dateFormatter.format(article.data.publishDate)}
            </p>
          </li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>
