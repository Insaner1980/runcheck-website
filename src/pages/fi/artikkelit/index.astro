---
import { getCollection } from 'astro:content';
import ArticleIndexPage from '../../../components/ArticleIndexPage.astro';
import { ARTICLE_HUBS_FI } from '../../../data/articleTaxonomy.fi.mjs';

const articles = (await getCollection('articles', ({ data }) => !data.draft && data.locale === 'fi'))
  .sort((a, b) => a.data.sourceNumber - b.data.sourceNumber);
---

<ArticleIndexPage locale="fi" articles={articles} hubs={ARTICLE_HUBS_FI} />
